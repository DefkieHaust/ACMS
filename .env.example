PORT=5000
MONGODB_URI=mongodb://localhost:27017/acms
JWT_SECRET=change-me-to-a-random-secret
JWT_EXPIRES_IN=7d
NODE_ENV=development

# Comma-separated list of allowed CORS origins (production only)
CORS_ORIGINS=http://localhost:5173,http://localhost:5000

# Email (optional — skipped when not configured)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@acms.app

# Payments (optional — simulated when not configured)
STRIPE_SECRET_KEY=
